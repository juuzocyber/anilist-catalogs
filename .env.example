# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────

# The host address the server binds to.
# Use 0.0.0.0 to accept connections from any network interface.
HOST=0.0.0.0

# The port the server listens on.
PORT=7000

# ── Security ──────────────────────────────────────────────────────────────────

# Secret key used for signing tokens and any server-side cryptography.
# Generate a secure value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── AniList OAuth ─────────────────────────────────────────────────────────────
# Required for the AniList profile login feature.
# Register your application at: https://anilist.co/settings/developer

# The Client ID assigned to your AniList application.
ANILIST_CLIENT_ID=your-anilist-client-id

# The Client Secret assigned to your AniList application.
ANILIST_CLIENT_SECRET=your-anilist-client-secret

# The OAuth callback URL registered with your AniList application.
# Must exactly match what you set in the AniList developer settings.
ANILIST_REDIRECT_URI=http://localhost:7000/auth/callback

# ── OpenRouter (optional) ──────────────────────────────────────────────────────
# Enables the AI Recommendations catalog. Users can also supply their own key
# via the configure UI — this server-side value is reserved for future use.
# Get a key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
